<!-- Hero Section -->
<div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="text-center max-w-3xl mx-auto">
            <h1 class="text-5xl font-bold text-gray-900 tracking-tight mb-4">
                Community Board
            </h1>
            <p class="text-xl text-gray-600 font-light">
                Helping you reconnect with your belongings.
            </p>
        </div>
    </div>
</div>

<!-- Action Bar -->
<div id="action-bar" class="bg-white\/95 border-b border-gray-100 backdrop-blur-sm bg-white/95 transition-all duration-200 ease-out transform-gpu">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <!-- Search and Actions -->
        <div class="flex flex-col lg:flex-row gap-3 items-stretch lg:items-end">
            <form action="/index" method="POST" class="flex-1 w-full">
                <!-- <label for="search" class="block text-sm font-medium text-gray-700 mb-2">
                    Search Query
                </label> -->
                <div class="flex flex-col md:flex-row gap-3">
                    <div class="relative flex-1">
                        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                        <input required 
                            type="text" 
                            name="query" 
                            id="search-item-query" 
                            placeholder="Search keys, wallets, pets..."
                            class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">
                    </div>
                    <% if (categories && categories.length) { %>
                        <select name="category" 
                                class="px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white text-gray-700 font-medium text-sm min-w-45">
                            <option value="">All categories</option>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.id %>"><%= category.name %></option>
                            <% }) %>
                        </select>
                    <% } %>
                    <button type="submit" 
                            class="inline-flex items-center justify-center w-full md:w-44 shrink-0 px-8 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-sm whitespace-nowrap">
                        Search Items
                    </button>
                </div>
            </form>
            <a href="/post/new" 
               class="inline-flex items-center justify-center w-full md:w-44 lg:w-44 md:ml-auto shrink-0 px-8 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-sm whitespace-nowrap">
                <span class="flex items-center space-x-2 justify-center w-full">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    <span>Post Item</span>
                </span>
            </a>
            
        </div>        
    </div>
</div>
<div id="action-bar-spacer" class="hidden" aria-hidden="true"></div>

<!-- Posts Grid -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
     <!-- Filter Buttons -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
            <button type="button" data-filter="All" 
                    class="filter-btn px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 bg-blue-600 text-white">
                All Items
            </button>
            <button type="button" data-filter="Lost" 
                    class="filter-btn px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-all duration-200">
                Lost
            </button>
            <button type="button" data-filter="Found" 
                    class="filter-btn px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-all duration-200">
                Found
            </button>
            <a href="/myPost" class="inline-flex items-center justify-center w-full md:w-44 lg:w-44 md:ml-auto shrink-0 px-8 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-sm whitespace-nowrap">My posts</a>
        </div><br>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% posts.forEach(post => { %>
            <div class="post-card group bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-xl hover:border-gray-300 transition-all duration-300 cursor-pointer" data-type="<%= post.type %>">
                <% if (post.cover_image) { %>
                    <div class="aspect-video overflow-hidden bg-gray-100">
                        <img src="/uploads/postCovers/<%= post.cover_image %>" 
                             alt="<%= post.title %>" 
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                    </div>
                <% } else { %>
                    <div class="aspect-video bg-gray-100 flex items-center justify-center">
                        <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                <% } %>
                
                <div class="p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= post.type === 'Lost' ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %>">
                            <%= post.type %>
                        </span>
                        <span class="text-xs text-gray-500 flex items-center">
                            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            <%= post.location %>
                        </span>
                    </div>
                    
                    <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors duration-200">
                        <%= post.title %>
                    </h3>
                    
                    <p class="text-sm text-gray-600 line-clamp-2 leading-relaxed">
                        <%= post.description %>
                    </p>
                    <a href="/claim/<%= post._id %>" 
                       class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200">
                        Claim
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
    
    <% if (posts.length === 0) { %>
        <div class="text-center py-16">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No items found</h3>
            <p class="text-gray-600 mb-6">Be the first to post an item to the community board.</p>
            <a href="/post/new" 
               class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-sm">
                Post Your First Item
            </a>
        </div>
    <% } %>
</main>

<script>
// Frontend filtering functionality
const filterButtons = document.querySelectorAll('.filter-btn');
const postCards = document.querySelectorAll('.post-card');
const actionBar = document.getElementById('action-bar');
const actionBarSpacer = document.getElementById('action-bar-spacer');

let lastScrollTop = window.pageYOffset || document.documentElement.scrollTop;
const stickyStart = actionBar ? actionBar.offsetTop : 0;
let currentDirection = 'down';
let directionChangedAt = Date.now();
let directionTravel = 0;
let isStickyMounted = false;
let isStickyVisible = false;
let hideTimeoutId = null;

const DIRECTION_BACKOFF_MS = 120;
const MIN_DIRECTION_TRAVEL = 10;
const TOP_RELEASE_BUFFER = 8;
const ANIMATION_MS = 200;

function mountStickyHidden() {
    if (!actionBar || !actionBarSpacer || isStickyMounted) return;

    actionBar.classList.add('fixed', 'top-16', 'left-0', 'right-0', 'z-40');
    actionBar.classList.add('-translate-y-full', 'opacity-0', 'pointer-events-none');
    actionBar.classList.remove('translate-y-0', 'opacity-100', 'shadow-sm');

    actionBarSpacer.style.height = actionBar.offsetHeight + 'px';
    actionBarSpacer.classList.remove('hidden');

    isStickyMounted = true;
    isStickyVisible = false;
}

function unmountSticky() {
    if (!actionBar || !actionBarSpacer) return;

    actionBar.classList.remove('fixed', 'top-16', 'left-0', 'right-0', 'z-40', '-translate-y-full', 'opacity-0', 'pointer-events-none', 'translate-y-0', 'opacity-100', 'shadow-sm');
    actionBarSpacer.classList.add('hidden');
    actionBarSpacer.style.height = '0px';

    isStickyMounted = false;
    isStickyVisible = false;
}

function showStickyActionBar() {
    if (!actionBar || !actionBarSpacer) return;

    if (hideTimeoutId) {
        clearTimeout(hideTimeoutId);
        hideTimeoutId = null;
    }

    if (!isStickyMounted) {
        mountStickyHidden();
    }

    requestAnimationFrame(() => {
        if (!actionBar) return;

        actionBar.classList.remove('-translate-y-full', 'opacity-0', 'pointer-events-none');
        actionBar.classList.add('translate-y-0', 'opacity-100', 'shadow-sm');
        isStickyVisible = true;
    });
}

function hideStickyActionBar() {
    if (!actionBar || !actionBarSpacer) return;

    if (!isStickyMounted || !isStickyVisible) return;

    actionBar.classList.remove('translate-y-0', 'opacity-100', 'shadow-sm');
    actionBar.classList.add('-translate-y-full', 'opacity-0', 'pointer-events-none');
    isStickyVisible = false;

    if (hideTimeoutId) {
        clearTimeout(hideTimeoutId);
    }

    hideTimeoutId = setTimeout(() => {
        if (!isStickyVisible) {
            unmountSticky();
        }
        hideTimeoutId = null;
    }, ANIMATION_MS);
}

window.addEventListener('scroll', function() {
    if (!actionBar) return;

    const now = Date.now();
    const currentScroll = window.pageYOffset || document.documentElement.scrollTop;
    const delta = currentScroll - lastScrollTop;

    if (Math.abs(delta) < 1) {
        return;
    }

    const nextDirection = delta < 0 ? 'up' : 'down';

    if (nextDirection !== currentDirection) {
        currentDirection = nextDirection;
        directionChangedAt = now;
        directionTravel = Math.abs(delta);
    } else {
        directionTravel += Math.abs(delta);
    }

    const directionStable = (now - directionChangedAt) >= DIRECTION_BACKOFF_MS && directionTravel >= MIN_DIRECTION_TRAVEL;

    if (currentScroll <= stickyStart + TOP_RELEASE_BUFFER) {
        hideStickyActionBar();
    } else if (directionStable) {
        // Keep normal flow while scrolling down; show sticky only on stable upward scroll.
        if (currentDirection === 'up') {
            showStickyActionBar();
        } else {
            hideStickyActionBar();
        }
    }

    lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
});

filterButtons.forEach(button => {
    button.addEventListener('click', function() {
        const filterValue = this.getAttribute('data-filter');
        
        // Update active button styling
        filterButtons.forEach(btn => {
            btn.classList.remove('bg-blue-600', 'text-white');
            btn.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
        });
        this.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
        this.classList.add('bg-blue-600', 'text-white');
        
        // Filter posts
        postCards.forEach(card => {
            const postType = card.getAttribute('data-type');
            if (filterValue === 'All' || postType === filterValue) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    });
});
</script>