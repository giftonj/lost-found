<form action="/myPost/verify/<%= post._id %>" method="POST">
    <label for="name">Name</label>
    <input type="text" name="name" placeholder="Enter the claimants name" required><br>
    <label for="email">Email</label>
    <input type="email" name="email" placeholder="Enter the claimants email" required><br>
    <label for="phoneNo">Phone Number</label>
    <input type="Number" name="phoneNo" placeholder="Enter the claimants phone number"><br>
    <a href="/myPost">Cancel</a>
    <button type="submit">Verify</button>
</form>