<section class="mt-14 sm:mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 sm:py-3">
        <div class="max-w-3xl">
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">My posts</h1>
            <p class="mt-2 text-sm sm:text-base text-gray-600">Manage your lost and found listings in one place.</p>
        </div>
    </div>
</section>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-12 pb-7 sm:pb-9">
    <% if (post && post.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            <% post.forEach(p => { %>
                <article class="group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-xl hover:border-gray-300 transition-all duration-300 min-w-0">
                    <% if (p.cover_image) { %>
                        <div class="aspect-video overflow-hidden bg-gray-100">
                            <img src="/uploads/postCovers/<%= p.cover_image %>"
                                 alt="<%= p.title %>"
                                 class="block w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                        </div>
                    <% } else { %>
                        <div class="aspect-video bg-gray-100 flex items-center justify-center">
                            <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                    <% } %>

                    <div class="p-5">
                        <div class="flex items-center gap-2 mb-3 min-w-0">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= p.type === 'Lost' ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %>">
                                <%= p.type %>
                            </span>
                            <span class="text-xs text-gray-500 flex items-center min-w-0 truncate">
                                <svg class="w-3 h-3 mr-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <span class="truncate"><%= p.location %></span>
                            </span>
                        </div>

                        <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors duration-200 line-clamp-2 wrap-break-word">
                            <%= p.title %>
                        </h3>

                        <p class="text-sm text-gray-600 line-clamp-3 leading-relaxed wrap-break-word">
                            <%= p.description %>
                        </p>

                        <div class="mt-5 flex flex-wrap gap-2">
                            <a href="/myPost/verify/<%= p._id %>" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-sm">Verify</a>
                            <a href="/myPost/edit/<%= p._id %>" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-lg transition-all duration-200">Edit</a>
                            <a href="#" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-lg transition-all duration-200">Delete</a>
                        </div>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-16 bg-white border border-gray-200 rounded-xl">
            <p class="text-gray-500 italic mb-4">No posts found</p>
            <a href="/index" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-sm">Back to Board</a>
        </div>
    <% } %>
</main>