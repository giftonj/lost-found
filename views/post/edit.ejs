<div class="min-h-screen py-8 sm:py-10 lg:py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
        <div class="mb-6 sm:mb-8">
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Edit Post</h2>
            <p class="text-sm sm:text-base text-gray-600">Update details for your lost or found item.</p>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-5 sm:p-6 lg:p-8 shadow-sm">
            <form action="/myPost/edit/<%= post._id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
                <!-- Item Name -->
                <div>
                    <label for="itemname" class="block text-sm font-medium text-gray-700 mb-2">
                        Item Name
                    </label>
                    <input type="text" 
                        id="itemname" 
                        name="title" 
                        value="<%= post.title %>" 
                        placeholder="e.g., Black iPhone, Blue Backpack" 
                        required
                         class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">
                </div>

                <!-- Description -->
                <div>
                    <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
                        Description
                    </label>
                    <textarea name="description" 
                            id="description" 
                            rows="4" 
                            placeholder="Provide detailed description to help identify the item..." 
                            required
                            class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 resize-none"><%= post.description %></textarea>
                </div>

                <!-- Type and Category Row -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="type" class="block text-sm font-medium text-gray-700 mb-2">
                            Type
                        </label>
                        <select name="type" 
                                id="type" 
                                 class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white">
                            <option value="Lost" <%= post.type === 'Lost' ? 'selected' : '' %>>Lost</option>
                            <option value="Found" <%= post.type === 'Found' ? 'selected' : '' %>>Found</option>
                        </select>
                    </div>

                    <div>
                        <label for="category" class="block text-sm font-medium text-gray-700 mb-2">
                            Category
                        </label>
                        <select name="category" 
                                id="category" 
                                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white"    >
                            <% categories.forEach(category => { %>
                                <option value="<%= category.id %>" <%= category.id === post.category ? 'selected' : '' %>>
                                    <%= category.name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <!-- Location and Status Row -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="location" class="block text-sm font-medium text-gray-700 mb-2">
                            Location
                        </label>
                        <input type="text" 
                            id="location" 
                            name="location" 
                            value="<%= post.location %>" 
                            placeholder="Where was it lost/found?" 
                             class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">
                    </div>
                </div>

                <!-- Cover Image -->
                <div>
                    <label for="cover-image" class="block text-sm font-medium text-gray-700 mb-2">
                        Cover Image
                    </label>
                    <div class="relative">
                        <input type="file" 
                            id="cover-image" 
                            value="<%= post.cover_image %>"
                            name="cover-image" 
                            accept="image/*"
                            class="block w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200 file:cursor-pointer cursor-pointer border border-gray-200 rounded-lg">
                    </div>
                    <p class="mt-2 text-xs text-gray-500">Upload a clear image of the item (PNG, JPG, or GIF)</p>
                </div>

                <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-end gap-2 sm:gap-3 pt-2 sm:pt-4 border-t border-gray-100">
                    <a href="/myPost" class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-all duration-200 w-full sm:w-auto">Cancel</a>
                    <button type="submit" class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-all duration-200 shadow-sm w-full sm:w-auto">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>