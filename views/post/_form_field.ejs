<div>
    <label for="description" class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 ml-1">
        <i class="fas fa-align-left mr-1 text-blue-500"></i> Description
    </label>                        
    <textarea name="description" id="description" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-blue-500/10 bg-white transition-all text-gray-700"><%= post.description %></textarea>
 </div>                                   
